# ─── AlphaTrade Markets — Environment Variables ──────────────────────────────
# Copy this file to .env.local and fill in your real values.
# NEVER commit .env.local to version control.

# ─── Firebase ─────────────────────────────────────────────────────────────────
# Get these from Firebase Console → Project Settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ─── Market data API ──────────────────────────────────────────────────────────
# Supported providers: twelve_data | alpha_vantage | finnhub | polygon | mock
# Leave NEXT_PUBLIC_MARKET_DATA_PROVIDER=mock to use built-in mock data.
NEXT_PUBLIC_MARKET_DATA_PROVIDER=mock
NEXT_PUBLIC_MARKET_DATA_API_KEY=

# Optional: WebSocket endpoint for real-time price streaming
# NEXT_PUBLIC_WS_MARKET_URL=wss://ws.twelvedata.com/v1/quotes/price

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=AlphaTrade Markets

# ─── Analytics (optional) ─────────────────────────────────────────────────────
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ─── Payment gateway (optional) ───────────────────────────────────────────────
# Only needed if you wire up card payments directly (vs. Firebase Cloud Function)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# STRIPE_SECRET_KEY=sk_test_...

# ─── Email (server-side only) ─────────────────────────────────────────────────
# Used by Cloud Functions / API routes for transactional email
# SENDGRID_API_KEY=SG.xxx
# SENDGRID_FROM_EMAIL=no-reply@alphatrademarkets.com

# ─── Admin ────────────────────────────────────────────────────────────────────
# Secret used to sign admin JWT tokens (server-side only)
# ADMIN_JWT_SECRET=change-me-to-a-long-random-string
